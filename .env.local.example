# Supabase — completar tras crear proyecto "empb-colombia"
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Opcional: usar service role solo en server-side (mayor seguridad para INSERT
# si decides no exponer la policy pública). NO commitear este valor.
SUPABASE_SERVICE_ROLE_KEY=

# NCBI E-utilities (PubMed widgets) — requisitos NCBI: tool + email
NCBI_TOOL=empb-colombia
NCBI_EMAIL=ifgutierrez@colsanitas.com
# Opcional: sube rate limit 3→10 req/s. https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# Vercel Cron — protege /api/cron/refresh. Generar con: openssl rand -hex 32
CRON_SECRET=
